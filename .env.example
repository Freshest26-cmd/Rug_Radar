# Rug Radar Scanner API Configuration
# Use these environment variables to configure your scanner

# Port for the server
PORT=3000

# Secret for hashing API keys (Change this in production!)
API_KEY_SECRET=your_system_secret

# Database URL (Neon.tech or other PostgreSQL)
# Format: postgresql://user:password@host:port/dbname?sslmode=require
DATABASE_URL=

# Backend WebSocket URL (For Frontend)
# Set this to your production domain (e.g., wss://rugradar.koyeb.app)
VITE_WS_URL=

# Lemon Squeezy Configuration (For Payments)
LEMON_SQUEEZY_STORE_ID=
LEMON_SQUEEZY_API_KEY=
LEMON_SQUEEZY_WEBHOOK_SECRET=
LEMON_SQUEEZY_VAR_PRO=
LEMON_SQUEEZY_VAR_WHALE=

# RapidAPI Configuration
# Use this to verify that requests are coming through your RapidAPI gateway
RAPIDAPI_PROXY_SECRET=
